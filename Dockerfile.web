# xiaozhi-bridge web Dockerfile
#
# Multi-stage build for the React admin console.
# Stage 1: build with Node + pnpm
# Stage 2: serve static files via Caddy (or nginx)

# ============================================================
# Stage 1: build
# ============================================================
FROM node:22-alpine AS builder

# Install pnpm (pin to a version that still runs build scripts by default
# so we don't have to wire up `pnpm.onlyBuiltDependencies` approval files
# for esbuild's native binary postinstall).
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

WORKDIR /app

# Copy package files first (cache)
COPY web/package.json web/pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile || pnpm install

# Copy source and build
COPY web/ ./
RUN pnpm build

# ============================================================
# Stage 2: runtime — Caddy
# ============================================================
FROM caddy:2-alpine AS runtime

# Install tzdata and set timezone (default: Asia/Shanghai = UTC+8).
# Override at runtime with `TZ=America/New_York` etc.
ARG TZ=Asia/Shanghai
RUN apk add --no-cache tzdata && \
    cp /usr/share/zoneinfo/$TZ /etc/localtime && \
    echo $TZ > /etc/timezone

# Copy built assets
COPY --from=builder /app/dist /srv

# Copy Caddyfile (inherited from deploy/)
# Note: We provide a default Caddyfile in deploy/ for full project;
# this one is a minimal SPA fallback.
RUN cat > /etc/caddy/Caddyfile <<'EOF'
:80 {
    root * /srv
    encode gzip zstd
    try_files {path} {path}/ /index.html
    file_server
}
EOF

EXPOSE 80
