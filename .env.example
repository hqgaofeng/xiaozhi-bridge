# xiaozhi-bridge environment configuration
#
# Copy to .env and fill in. Loaded by docker compose automatically.
# Never commit .env to git (it's in .gitignore).

# === Logging ===
# Bridge log level. One of DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# === V2 (NOT used in V1) ===
# V2 will add real ASR / TTS provider keys. Examples for V2:
#   ALIYUN_AK_ID=
#   ALIYUN_AK_SECRET=
#   ALIYUN_ASR_APP_KEY=
#   XIAOZHI_TTS__VOICE=zh-CN-XiaoxiaoNeural
#   EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
# V1 ships with mock ASR + mock TTS — no keys needed.
#
# V2 #1: sherpa-onnx is now the default ASR provider. No env vars
# needed (no cloud credentials). The model directory is hard-coded
# in config/config.yaml (asr.options.model_dir) and bind-mounted
# from the host in docker-compose.yml:
#   /opt/xiaozhi-bridge/models  →  /opt/xiaozhi-bridge/models (ro)
# To use a different model, edit config/config.yaml — no rebuild.
# To temporarily fall back to mock ASR (no model load at all), set
# in config/config.yaml: asr.provider: mock

# === Domain / TLS (NOT used in V1) ===
# V1 uses the host's existing nginx + Let's Encrypt for HTTPS. No
# PUBLIC_DOMAIN / ACME_EMAIL needed in the container; configure those
# on the host's nginx + certbot directly. See docs/deployment-docker.md
# §2.4 for the nginx conf template.
