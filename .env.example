# xiaozhi-bridge environment configuration
#
# Copy to .env and fill in. Loaded by docker compose automatically.
# Never commit .env to git (it's in .gitignore).

# === Logging ===
LOG_LEVEL=INFO

# === OpenClaw auth ===
# These get injected into the openclaw config.
# Get a MiniMax API key from https://api.minimax.io
MINIMAX_API_KEY=sk-cp-your-key-here

# === Bridge / Device auth (optional) ===
# If set, devices must send this as Bearer token
XIAOZHI_DEVICE__AUTH_TOKEN=

# === ASR / TTS (V2: real providers) ===
# Aliyun ASR (V2)
ALIYUN_AK_ID=
ALIYUN_AK_SECRET=
ALIYUN_ASR_APP_KEY=

# Edge TTS voice
XIAOZHI_TTS__VOICE=zh-CN-XiaoxiaoNeural

# === Domain (for Caddy HTTPS) ===
# Example: xiaozhi.example.com
PUBLIC_DOMAIN=
# Optional: email for Let's Encrypt notifications
ACME_EMAIL=
