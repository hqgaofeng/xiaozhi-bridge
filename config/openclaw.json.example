{
  "_comment": "OpenClaw gateway config. Copy to openclaw.json and edit.",
  "_docs": "See https://docs.openclaw.ai for full schema. This file is mounted into the openclaw container at /root/.openclaw/openclaw.json.",
  "gateway": {
    "port": 18789,
    "host": "0.0.0.0"
  },
  "providers": {
    "minimax-cn-api": {
      "type": "minimax",
      "baseUrl": "https://api.minimax.io",
      "apiKey": "${MINIMAX_API_KEY}"
    }
  },
  "defaultModel": "minimax/MiniMax-M3",
  "logging": {
    "level": "info"
  }
}
