# xiaozhi-bridge Caddy config
#
# Caddy handles automatic HTTPS via Let's Encrypt.
# Install: https://caddyserver.com/docs/install

# IMPORTANT: Replace YOUR_DOMAIN below with your actual domain.
# For local-only deployments, you can remove the auto-HTTPS parts.

YOUR_DOMAIN {
    encode gzip zstd

    # Web admin UI (built static files)
    root * /root/projects/xiaozhi-bridge/web/dist
    file_server

    # Bridge HTTP API (V2)
    reverse_proxy /api/* 127.0.0.1:8000

    # Bridge WebSocket endpoint
    reverse_proxy /xiaozhi/* 127.0.0.1:8000

    # Optional: health check endpoint
    reverse_proxy /health 127.0.0.1:8000

    log {
        output file /var/log/caddy/xiaozhi-bridge.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}

# Optional: redirect www to apex
# www.YOUR_DOMAIN {
#     redir https://YOUR_DOMAIN{uri} permanent
# }
